{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "gradle: prepare desktop run",
      "type": "shell",
      "command": "${workspaceFolder}\\gradlew.bat",
      "args": [":core:classes", ":lwjgl3:classes", "--no-daemon"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "gradle: run desktop",
      "type": "shell",
      "command": "${workspaceFolder}\\gradlew.bat",
      "args": ["lwjgl3:run", "--no-daemon"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "gradle: build",
      "type": "shell",
      "command": "${workspaceFolder}\\gradlew.bat",
      "args": ["build", "--no-daemon"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
